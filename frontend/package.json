{
  "name": "lms-rikkei-edu",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "LMS Rikkei Edu — Learning Management System UI (React + TypeScript + Vite)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepare": "node -e \"if (require('fs').existsSync('.git')) require('child_process').execSync('husky', {stdio:'inherit'})\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ckeditor/ckeditor5-react": "^11.2.0",
    "@stomp/stompjs": "^7.3.0",
    "axios": "^1.18.0",
    "ckeditor5": "^48.2.0",
    "docx-preview": "^0.4.0",
    "dompurify": "^3.4.11",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-pdf": "^10.4.1",
    "react-router-dom": "^7.17.0",
    "sockjs-client": "^1.6.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/sockjs-client": "^1.5.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^10.5.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^6.4.3",
    "vitest": "^4.1.10"
  }
}
